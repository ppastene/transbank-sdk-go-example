{{ define "webpayplusmall/deferred/malltransaction_captured.tmpl" }}
    {{ template "header" . }}
    <h2>{{ .title }}</h2>
    <h3>Request</h3>
    <ul>
    {{ range $key, $value := .request }}
        <li>{{ $key }}: {{ $value }}</li>
    {{ end }}
    </ul>
    <h3>Response</h3>
    <ul>
        <li>AuthorizationCode: {{ .response.AuthorizationCode }}</li>
        <li>AuthorizationDate: {{ .response.AuthorizationDate }}</li>
        <li>CapturedAmount: {{ .response.CapturedAmount }}</li>
        <li>ResponseCode: {{ .response.ResponseCode }}</li>
    </ul>

    {{ template "footer" . }}
{{ end }}